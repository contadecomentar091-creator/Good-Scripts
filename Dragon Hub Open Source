	scroll.Size = UDim2.new(1, -12, 1, -40); scroll.Position = UDim2.new(0, 6, 0, 36)
	scroll.BackgroundTransparency = 1; scroll.BorderSizePixel = 0; scroll.ScrollBarThickness = 4
	scroll.ScrollBarImageColor3 = Color3.fromRGB(40, 100, 220); scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.CanvasSize = UDim2.new(0, 0, 0, 0); scroll.Parent = f
	local sl2 = Instance.new('UIListLayout', scroll)
	sl2.SortOrder = Enum.SortOrder.LayoutOrder; sl2.Padding = UDim.new(0, 4)
	local sp2 = Instance.new('UIPadding', scroll)
	sp2.PaddingTop = UDim.new(0, 4); sp2.PaddingBottom = UDim.new(0, 4)
	local empty = Instance.new('TextLabel')
	empty.Size = UDim2.new(1, 0, 0, 32); empty.BackgroundTransparency = 1
	empty.Text = 'No targets found'; empty.TextColor3 = Color3.fromRGB(80, 100, 130)
	empty.TextSize = 12; empty.Font = Enum.Font.Gotham; empty.LayoutOrder = 1; empty.Parent = scroll
	local pool = {}

	local function refreshList()
		if guiDestroyed then return end
		for _, b in ipairs(pool) do b:Destroy() end
		pool = {}
		buildTargets()
		empty.Visible = (#targets == 0)
		cnt.Text = '('..#targets..')'
		local isNone = (currentTarget == nil)
		local nb = Instance.new('TextButton')
		nb.Size = UDim2.new(1, -6, 0, 32)
		nb.BackgroundColor3 = isNone and Color3.fromRGB(60, 30, 30) or Color3.fromRGB(18, 25, 42)
		nb.Text = ''; nb.LayoutOrder = 0; nb.Parent = scroll
		Instance.new('UICorner', nb).CornerRadius = UDim.new(0, 7)
		local nbs = Instance.new('UIStroke', nb)
		nbs.Color = isNone and Color3.fromRGB(200, 80, 80) or Color3.fromRGB(30, 60, 120); nbs.Thickness = 1
		local nd = Instance.new('Frame')
		nd.Size = UDim2.new(0, 8, 0, 8); nd.Position = UDim2.new(0, 10, 0.5, -4)
		nd.BackgroundColor3 = isNone and Color3.fromRGB(220, 80, 80) or Color3.fromRGB(80, 120, 180)
		nd.BorderSizePixel = 0; nd.Parent = nb
		Instance.new('UICorner', nd).CornerRadius = UDim.new(1, 0)
		local nn = Instance.new('TextLabel')
		nn.Size = UDim2.new(1, -30, 1, 0); nn.Position = UDim2.new(0, 26, 0, 0)
		nn.BackgroundTransparency = 1; nn.Text = '— None (idle)'
		nn.TextColor3 = isNone and Color3.fromRGB(220, 120, 120) or Color3.fromRGB(140, 160, 190)
		nn.TextSize = 12; nn.Font = Enum.Font.Gotham
		nn.TextXAlignment = Enum.TextXAlignment.Left; nn.Parent = nb
		nb.MouseButton1Click:Connect(function()
			currentTarget = nil; targetIndex = 0; updateStatus(); refreshList()
		end)
		table.insert(pool, nb)
		for i, t in ipairs(targets) do
			local sel = (currentTarget == t)
			local btn = Instance.new('TextButton')
			btn.Size = UDim2.new(1, -6, 0, 32)
			btn.BackgroundColor3 = sel and Color3.fromRGB(30, 90, 180) or Color3.fromRGB(18, 25, 42)
			btn.Text = ''; btn.LayoutOrder = i; btn.Parent = scroll
			Instance.new('UICorner', btn).CornerRadius = UDim.new(0, 7)
			local bs = Instance.new('UIStroke', btn)
			bs.Color = sel and Color3.fromRGB(60, 140, 255) or Color3.fromRGB(30, 60, 120); bs.Thickness = 1
			local d = Instance.new('Frame')
			d.Size = UDim2.new(0, 8, 0, 8); d.Position = UDim2.new(0, 10, 0.5, -4)
			d.BackgroundColor3 = sel and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(80, 120, 180)
			d.BorderSizePixel = 0; d.Parent = btn
			Instance.new('UICorner', d).CornerRadius = UDim.new(1, 0)
			local n = Instance.new('TextLabel')
			n.Size = UDim2.new(1, -16, 1, 0); n.Position = UDim2.new(0, 26, 0, 0)
			n.BackgroundTransparency = 1
			n.Text = (t.Parent and t.Parent.Name) or 'Unknown'
			n.TextColor3 = sel and Color3.fromRGB(220, 240, 255) or Color3.fromRGB(180, 200, 230)
			n.TextSize = 12; n.Font = Enum.Font.Gotham
			n.TextXAlignment = Enum.TextXAlignment.Left; n.Parent = btn
			btn.MouseButton1Click:Connect(function()
				currentTarget = t; targetIndex = i; updateStatus(); refreshList()
			end)
			btn.MouseEnter:Connect(function()
				if currentTarget ~= t then
					TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 40, 65)}):Play()
				end
			end)
			btn.MouseLeave:Connect(function()
				if currentTarget ~= t then
					TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(18, 25, 42)}):Play()
				end
			end)
			table.insert(pool, btn)
		end
		updateStatus()
	end

	triggerListRefresh = refreshList
	ref.MouseButton1Click:Connect(refreshList)
	task.spawn(function()
		while gui.Parent do
			if guiDestroyed then break end
			refreshList(); task.wait(2)
		end
	end)
	refreshList()
end

