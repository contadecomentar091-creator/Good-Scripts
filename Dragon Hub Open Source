local deathWatchConn = nil
local function hookDeathWatch()
	if deathWatchConn then deathWatchConn:Disconnect(); deathWatchConn = nil end
	local hum = char and char:FindFirstChildWhichIsA('Humanoid')
	if not hum then return end
	deathWatchConn = hum.Died:Connect(function()
		if enabled then
			enabled = false
			if enableToggle then enableToggle.setState(false) end
			stop(); stopCycle()
		end
		if deathFlingEnabled then
			deathFlingEnabled = false
			if deathFlingToggle then deathFlingToggle.setState(false) end
			stopDeathFling()
		end
		triggerListRefresh()
	end)
end

hookDeathWatch()

local function buildTargets()
	targets = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp and p.Character then
			local h = p.Character:FindFirstChild('HumanoidRootPart')
			if h then table.insert(targets, h) end
		end
	end
	local folder = workspace:FindFirstChild('Characters')
	if folder then
		for _, model in ipairs(folder:GetChildren()) do
			if model ~= char and not string.find(model.Name, '_Decoy') then
				local h = model:FindFirstChild('HumanoidRootPart')
				if h then table.insert(targets, h) end
			end
		end
	end
end

local function getNearestToMouse()
	buildTargets()
	local mp = UserInputService:GetMouseLocation()
	local shortest, nearest, nearestIdx = math.huge, nil, 0
	for i, t in ipairs(targets) do
		if t and t.Parent then
			local sp, on = camera:WorldToViewportPoint(t.Position)
			if on then
				local dist = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
				if dist < shortest then
					shortest = dist; nearest = t; nearestIdx = i
				end
			end
		end
	end
	return nearest, nearestIdx
end

local function cycleTarget(forward)
	buildTargets()
	if #targets == 0 then currentTarget = nil; return end
	if forward then
		targetIndex = (targetIndex % #targets) + 1
	else
		targetIndex = ((targetIndex - 2) % #targets) + 1
	end
	currentTarget = targets[targetIndex]
end

local function tpBypass(targetCF)
	if not hrp or not hrp.Parent then return end
	local i = 0; local conn
	conn = RunService.Heartbeat:Connect(function()
		i += 1
		hrp.CFrame = targetCF
		if i >= 11 then
			conn:Disconnect()
			hrp.CFrame = targetCF
		end
	end)
end

local function startDeathFling()
	if deathFlingConn then deathFlingConn:Disconnect() end
	deathFlingConn = RunService.Heartbeat:Connect(function()
		local hum = char and char:FindFirstChild('Humanoid')
		if not hum then return end
		pcall(function()
			sethiddenproperty(hum, 'MoveDirectionInternal', Vector3.new(0/0, 0/0, 0/0))
			sethiddenproperty(hum, 'NetworkHumanoidState', Enum.HumanoidStateType.Freefall)
		end)
	end)
end

local function stopDeathFling()
	if deathFlingConn then deathFlingConn:Disconnect(); deathFlingConn = nil end
	local hum = char and char:FindFirstChild('Humanoid')
	if hum then
		pcall(function()
			sethiddenproperty(hum, 'MoveDirectionInternal', Vector3.zero)
			sethiddenproperty(hum, 'NetworkHumanoidState', Enum.HumanoidStateType.Running)
		end)
	end
end

local function updateHRP()
	if not hrp or not hrp.Parent then return end
	if not currentTarget or not currentTarget.Parent then
		if savedPos then
			local relOff = CFrame.new(offsetX, offsetY, offsetZ)
			local relRot = CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
			hrp.CFrame = savedPos * relOff * relRot
		end
		return
	end
	local relOff = CFrame.new(offsetX, offsetY, offsetZ)
	local relRot = CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
	hrp.CFrame = currentTarget.CFrame * relOff * relRot
end

local function start()
	if mainConn then mainConn:Disconnect() end
	if hrp and hrp.Parent then savedPos = hrp.CFrame end
	workspace.FallenPartsDestroyHeight = fallenHeight
	mainConn = RunService.Heartbeat:Connect(function()
		if enabled then pcall(updateHRP) end
	end)
end

local function stop()
	if mainConn then mainConn:Disconnect(); mainConn = nil end
	workspace.FallenPartsDestroyHeight = originalFallen
	if savedPos and hrp and hrp.Parent then
		tpBypass(savedPos)
		savedPos = nil
	end
	currentTarget = nil
	targetIndex = 0
end

local function startCycle()
	if cycleConn then cycleConn:Disconnect() end
	cycleConn = RunService.Heartbeat:Connect(function()
		if not enabled or not autoCycle then return end
		buildTargets()
		if #targets == 0 then return end
		targetIndex = (targetIndex % #targets) + 1
		currentTarget = targets[targetIndex]
	end)
end

local function stopCycle()
	if cycleConn then cycleConn:Disconnect(); cycleConn = nil end
end

local function doInstantRespawn()
	buildTargets()
	if #targets == 0 then return end
	local t = targets[math.random(1, #targets)]
	if not t or not t.Parent then return end
	currentTarget = t
	if not deathFlingEnabled then
		deathFlingEnabled = true
		deathFlingToggle.setState(true)
		startDeathFling()
	end
	if not enabled then
		enabled = true
		enableToggle.setState(true)
		start()
	end
	updateStatus()
	triggerListRefresh()
end

local function destroyAll()
	if guiDestroyed then return end
	guiDestroyed = true
	if inputConn then inputConn:Disconnect(); inputConn = nil end
	if charConn then charConn:Disconnect(); charConn = nil end
	if deathWatchConn then deathWatchConn:Disconnect(); deathWatchConn = nil end
	stop()
	stopCycle()
	stopDeathFling()
	workspace.FallenPartsDestroyHeight = originalFallen
end

