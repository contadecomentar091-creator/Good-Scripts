inputConn = UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe or guiDestroyed then return end
	if input.KeyCode == Enum.KeyCode.Y then
		enabled = not enabled
		enableToggle.setState(enabled)
		if enabled then start(); if autoCycle then startCycle() end
		else stop(); stopCycle() end
		updateStatus(); triggerListRefresh()
	elseif input.KeyCode == Enum.KeyCode.H then
		autoCycle = not autoCycle
		autoCycleToggle.setState(autoCycle)
		if autoCycle and enabled then startCycle() else stopCycle() end
	elseif input.KeyCode == Enum.KeyCode.J then
		deathFlingEnabled = not deathFlingEnabled
		deathFlingToggle.setState(deathFlingEnabled)
		if deathFlingEnabled then startDeathFling() else stopDeathFling() end
	elseif input.KeyCode == Enum.KeyCode.K then
		doInstantRespawn()
	elseif input.KeyCode == Enum.KeyCode.Z then
		local shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
		cycleTarget(not shift); updateStatus(); triggerListRefresh()
	elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
		local t, i = getNearestToMouse()
		if t then
			currentTarget = t; targetIndex = i
			if not enabled then
				enabled = true; enableToggle.setState(true); start()
			end
			updateStatus(); triggerListRefresh()
		end
	end
end)

charConn = lp.CharacterAdded:Connect(function(newChar)
	if guiDestroyed then return end
	char = newChar
	hrp = newChar:WaitForChild('HumanoidRootPart')
	humanoid = newChar:WaitForChild('Humanoid')
	enabled = false; autoCycle = false
	deathFlingEnabled = false
	currentTarget = nil
	targetIndex = 0; savedPos = nil
	enableToggle.setState(false); autoCycleToggle.setState(false)
	deathFlingToggle.setState(false)
	stopCycle(); stopDeathFling()
	task.defer(hookDeathWatch)
	updateStatus(); triggerListRefresh()
end)

