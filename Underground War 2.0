-- Função de Arrastar (Corrigida)
local function MakeDraggable(gui)
	local UserInputService = game:GetService("UserInputService")
	local dragging, dragInput, dragStart, startPos

	gui.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = gui.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	gui.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end

MakeDraggable(Frame)
MakeDraggable(OpenButton)

-- Eventos de clique (Corrigidos)
TextButton.MouseButton1Click:Connect(function()
	Frame.Visible = false
	OpenButton.Visible = true
end)

OpenButton.MouseButton1Click:Connect(function()
	OpenButton.Visible = false
	Frame.Visible = true
end)

TextButton_2.MouseButton1Click:Connect(function()
	reachType = (reachType == "Sphere") and "Line" or "Sphere"
	TextButton_2.Text = reachType
end)

-- Loop Principal Seguro e Otimizado
local plr = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

RunService.RenderStepped:Connect(function()
	if not active or not trueActive then 
		visualizer.Parent = nil
		return 
	end

	local character = plr.Character
	if not character then 
		visualizer.Parent = nil 
		return 
	end

	local tool = character:FindFirstChildOfClass("Tool")
	local handle = tool and tool:FindFirstChild("Handle")

	if not handle then
		visualizer.Parent = nil
		return
	end

	local reach = tonumber(TextBox.Text) or 0
	if reach <= 0 then
		visualizer.Parent = nil
		return
	end
	
	-- ATUALIZAÇÃO DO VISUALIZADOR: Limitado estritamente a 49 para a mesh/part não bugar no motor gráfico,
	-- mas a distância real matemática do hit continua aceitando valores maiores (100, 200, etc.)
	if visualizerEnabled then
		local visualSize = math.clamp(reach, 0, 49)
		visualizer.Size = Vector3.new(visualSize, visualSize, visualSize)
		visualizer.CFrame = handle.CFrame
		if visualizer.Parent ~= workspace then
			visualizer.Parent = workspace
		end
	else
		visualizer.Parent = nil
	end

	-- Lógica de Hit por Tabela Local (Impede lags estruturais)
	local players = game.Players:GetPlayers()
	local originPos = handle.Position

	for i = 1, #players do
		local targetPlr = players[i]
		if targetPlr ~= plr and targetPlr.Character then
			local hrp = targetPlr.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local distance = (hrp.Position - originPos).Magnitude
				if distance <= reach then
					firetouchinterest(hrp, handle, 0)
					firetouchinterest(hrp, handle, 1)
				end
			end
		end
	end
end)

-- Atalho de teclado
game:GetService("UserInputService").InputBegan:Connect(function(i, gp)
	if gp then return end
	if i.KeyCode == Enum.KeyCode.H then
		if Frame.Visible or OpenButton.Visible then
			Frame.Visible = false
			OpenButton.Visible = false
		else
			Frame.Visible = true
		end
	end
end)
