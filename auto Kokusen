-- TARGET FINDER
local function findNearestTarget()
    local hrp = getHRP()
    if not hrp then return nil end

    local myChar = LocalPlayer.Character
    local nearest = nil
    local bestDist = math.huge

    local function checkModel(model)
        if not isAliveModel(model,myChar) then return end

        local root = model:FindFirstChild("HumanoidRootPart")
        local dist = (hrp.Position - root.Position).Magnitude

        if dist < bestDist then
            bestDist = dist
            nearest = model
        end
    end

    for _,player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            checkModel(player.Character)
        end
    end

    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            checkModel(obj)
        end
    end

    return nearest
end

-- 🔥 DASH CURVADO PERFEITO (NÃO ENCURTA)
local function curvedDashBehind(targetRoot, duration, customOffset)

    local char = LocalPlayer.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")

    if not hrp or not hum or not targetRoot then return end

    hum.AutoRotate = false

    local startTime = tick()
    local startPos = hrp.Position 

    -- ADICIONADO: Permite usar uma distância customizada (ex: tween curto)
    local offsetDistance = customOffset or CONFIG.BehindOffset

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not targetRoot or not targetRoot.Parent then
            hum.AutoRotate = true
            conn:Disconnect()
            return
        end

        local elapsed = tick() - startTime
        local alpha = math.clamp(elapsed / duration, 0, 1)

        if alpha >= 1 then
            hum.AutoRotate = true
            conn:Disconnect()
            return
        end

        local smoothAlpha = 1 - (1 - alpha)^3
        local enemyCF = targetRoot.CFrame
        local enemyPos = enemyCF.Position
        
        -- Aplica a distância definida (curta ou normal) nas costas do inimigo
        local behindPos = enemyPos - (enemyCF.LookVector * offsetDistance)
        local basePos = startPos:Lerp(behindPos, smoothAlpha)
        local curve = enemyCF.RightVector * math.sin(smoothAlpha * math.pi) * offsetDistance
        local finalPos = basePos + curve

        hrp.CFrame = CFrame.lookAt(finalPos, enemyPos)
    end)
end

-- HOOK
local isCooling = false

local oldNamecall
oldNamecall = hookmetamethod(game,"__namecall",function(self,...)

    if getnamecallmethod() ~= "FireServer" or self ~= targetRemote then
        return oldNamecall(self,...)
    end

    if not Enabled then 
        return oldNamecall(self,...)
    end

    if isCooling then
        return oldNamecall(self,...)
    end

    isCooling = true

    local args = {...}
    local result = oldNamecall(self,...)

    task.delay(CONFIG.FireDelay,function()
        pcall(function()
            targetRemote:FireServer(table.unpack(args))
        end)
        isCooling = false
    end)

    task.delay(CONFIG.WarpDelay,function()
        local target = findNearestTarget()
        if not target then return end
        local targetRoot = target:FindFirstChild("HumanoidRootPart")
        if not targetRoot then return end

        local myHrp = getHRP()
        local chosenOffset = CONFIG.BehindOffset -- Distância padrão

        if myHrp then
            local enemyLook = targetRoot.CFrame.LookVector
            local myLook = myHrp.CFrame.LookVector
            local dotProduct = enemyLook:Dot(myLook)
            
            -- Se o inimigo já estiver de costas (olhando na mesma direção que você)
            if dotProduct > 0.5 then 
                return 
            end

            -- ADICIONADO: Se o inimigo estiver de lado para você (ângulo perpendicular entre -0.5 e 0.5)
            if math.abs(dotProduct) <= 0.5 then
                chosenOffset = CONFIG.BehindOffset * 0.5 -- Faz o tween ser mais curto pras costas dele
            end
        end

        curvedDashBehind(targetRoot, CONFIG.FireDelay, chosenOffset)
    end)

    return result
end)

